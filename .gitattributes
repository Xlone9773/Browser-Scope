# Force LF line endings for all text files and lock files to prevent Git diff issues (such as whole-file "all-green" additions)
* text=auto eol=lf
package-lock.json text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
