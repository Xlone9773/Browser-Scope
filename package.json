{
  "name": "browserscope",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "4.5.1",
    "@xenova/transformers": "2.17.1",
    "buffer": "6.0.3",
    "eruda": "^3.4.3",
    "eruda-timing": "^2.0.1",
    "express": "^5.2.1",
    "fingerprintjs2": "2.1.4",
    "fpjs-v5": "npm:@fingerprintjs/fingerprintjs@^5.2.0",
    "long": "5.2.3",
    "lucide-react": "^0.561.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vconsole": "^3.15.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "esbuild": "^0.28.0",
    "lightningcss": "^1.32.0",
    "tailwindcss": "^4.3.0",
    "terser": "^5.48.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-compression": "^0.5.1"
  }
}
