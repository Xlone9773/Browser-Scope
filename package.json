{
  "name": "browserscope",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "lint": "oxlint && eslint . --cache --cache-strategy content && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@fingerprintjs/fingerprintjs": "4.5.1",
    "@xenova/transformers": "2.17.1",
    "buffer": "6.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "eruda": "^3.4.3",
    "eruda-code": "^2.2.0",
    "eruda-features": "^2.1.0",
    "eruda-fps": "^2.0.0",
    "eruda-monitor": "^1.1.2",
    "eruda-timing": "^2.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "fingerprintjs2": "2.1.4",
    "fpjs-v5": "npm:@fingerprintjs/fingerprintjs@^5.2.0",
    "helmet": "^8.2.0",
    "html-to-image": "^1.11.13",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "long": "5.2.3",
    "lucide-react": "^0.561.0",
    "motion": "^12.42.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "vconsole": "^3.15.1",
    "workbox-precaching": "^7.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jscodeshift": "^17.3.0",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "^4.1.10",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-plugin-oxlint": "^1.73.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jscodeshift": "^17.3.0",
    "jsdom": "^29.1.1",
    "lightningcss": "^1.32.0",
    "lint-staged": "^17.0.8",
    "oxlint": "~1.73.0",
    "tailwindcss": "^4.3.0",
    "terser": "^5.48.0",
    "tsx": "^4.22.3",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.1.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "protobufjs": "^7.6.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ]
  }
}
